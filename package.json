{
  "name": "@endge/integration-api",
  "version": "0.1.1",
  "description": "Public contracts for Endge integrations",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "pnpm clean && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.8",
    "vue": "^3.5.24"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0"
}
